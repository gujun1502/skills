# ============================================================
# stock-tp 配置示例 —— 复制为 config.env 后填入你的值
#   cp config.example.env config.env
# 真实环境变量优先级高于本文件；config.env 不应提交到 git。
# ============================================================

# --- 自选股（观察名单，供批量/loop 使用）-----------------------
# A股6位 / 港股 hk00700 / 美股 AAPL / 日股 7203.T / 韩股 005930.KS
# 早盘重点观察名单（与 linkage.json 登记的标的对应）：
STOCK_LIST=002156,300223,603986,301308,688256,688371

# --- 新闻 / 舆情检索（强烈推荐）-------------------------------
# Anspire AI Search：https://aisearch.anspire.cn 注册取 Key
# 支持逗号分隔多 Key 轮换；同一 Key 可复用为 Anspire 大模型。
ANSPIRE_API_KEYS=

# --- 可选：无人值守(loop/cron)时的大模型综合层 -----------------
# 交互式运行时综合分析由 Claude 完成，无需配置以下项。
# OpenAI 兼容；端点与模型名以你 Anspire 控制台为准，也可指向 DeepSeek/Qwen 等兜底。
ANSPIRE_LLM_BASE_URL=https://api.anspire.cn/v1
ANSPIRE_LLM_MODEL=anspire-pro

# --- 可选：stock-tp 中长期决策权重覆盖（不填用默认；自动归一化）---
# 默认 消息0.22 情绪0.13 基本面0.25 技术0.22 资金0.18
# W_NEWS=0.22
# W_SENTIMENT=0.13
# W_FUND=0.25
# W_TECH=0.22
# W_CAPITAL=0.18

# --- 可选：早盘 premarket 五因子权重覆盖（不填用默认；自动归一化）-
# 默认 技术0.25 资金0.22 宏观隔夜0.20 板块联动0.18 情绪0.15
# 复盘后按 references/premarket-learning.md 的纪律微调（一次一项，幅度≤0.03）
# W_PM_TECH=0.25
# W_PM_CAPITAL=0.22
# W_PM_OVERNIGHT=0.20
# W_PM_LINKAGE=0.18
# W_PM_SENTIMENT=0.15
